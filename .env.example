# Telegram Bot Tokens (create bots at @BotFather)
MANAGEMENT_BOT_TOKEN=your_management_bot_token_here
CHANNEL_BOT_TOKEN=your_channel_bot_token_here

# Telegram Channel/Group IDs (e.g. @YourChannel or -100123456789)
TRENDING_CHANNEL_ID=@YourTrendingChannel
PRO_CHANNEL_ID=@YourProChannel

# Admin Telegram IDs (comma-separated)
ADMIN_IDS=123456789,987654321

# Solana Payment Wallet
SOL_PAYMENT_WALLET=YourSolanaWalletAddressHere
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Scanner Settings
SCAN_INTERVAL_MINUTES=3
MIN_MARKET_CAP=10000
MAX_MARKET_CAP=800000
MIN_VOLUME_1H=3000
MIN_PRICE_CHANGE_1H=10
MIN_BUY_SELL_RATIO=1.2
MAX_TOKEN_AGE_HOURS=48
CALL_COOLDOWN_MINUTES=15
MAX_CALLS_PER_HOUR=5

# Pricing (in SOL)
FAST_TRACK_3H_SOL=1.2
FAST_TRACK_12H_SOL=2.2
FAST_TRACK_24H_SOL=3.2
ADVERTISE_24H_SOL=3.5
PRO_MONTHLY_SOL=0.7

# Database
DB_PATH=./kabal.db
