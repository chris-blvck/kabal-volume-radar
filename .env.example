# ────────────────────────────────────────────────────────────
# Kabal Volume Radar — .env.example
# Copy to .env and fill your values
# ────────────────────────────────────────────────────────────

# TELEGRAM — create bots at @BotFather
MANAGEMENT_BOT_TOKEN=your_management_bot_token
CHANNEL_BOT_TOKEN=your_channel_bot_token

# Channel/Group IDs  (@YourChannel  or  -100123456789)
TRENDING_CHANNEL_ID=@YourTrendingChannel
PRO_CHANNEL_ID=@YourProChannel        # smart money alerts + pro content

# Comma-separated Telegram user IDs — grants /stats /call /broadcast /wallets /payouts
ADMIN_IDS=123456789,987654321

# SOLANA
SOL_PAYMENT_WALLET=YourSolanaWalletAddress
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# HELIUS — free at https://helius.dev
# Enables: holder analysis, bundle detection, wallet tracker
HELIUS_API_KEY=

# BIRDEYE — free at https://birdeye.so/developer
# Enables: volume-momentum trending, new listing sources (significantly improves call quality)
BIRDEYE_API_KEY=

# SCANNER FILTERS
SCAN_INTERVAL_MINUTES=3
MIN_MARKET_CAP=10000
MAX_MARKET_CAP=800000
MIN_VOLUME_1H=3000
MIN_PRICE_CHANGE_1H=10
MIN_BUY_SELL_RATIO=1.2
MAX_TOKEN_AGE_HOURS=48
CALL_COOLDOWN_MINUTES=15
MAX_CALLS_PER_HOUR=5
SKIP_HIGH_RISK_BUNDLES=true

# PRICING (SOL)
FAST_TRACK_3H_SOL=1.2
FAST_TRACK_12H_SOL=2.2
FAST_TRACK_24H_SOL=3.2
ADVERTISE_24H_SOL=3.5
PRO_MONTHLY_SOL=0.7

# REFERRAL
REFERRAL_COMMISSION_PCT=10   # % of each payment earned by the referrer

# DATABASE
DB_PATH=./kabal.db
